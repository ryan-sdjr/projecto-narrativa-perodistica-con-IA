---
/**
 * MarkdownSection: renderiza el body de una entrada de la colección `site`.
 * Útil para secciones que solo necesitan título + markdown libre.
 */
import { getEntry, render } from "astro:content";
import FadeIn from "../motion/FadeIn.astro";

interface Props {
  slug: string;
  class?: string;
  proseClass?: string;
  showTitle?: boolean;
}

const { slug, class: className = "", proseClass = "", showTitle = true } = Astro.props;
const entry = await getEntry("site", slug);
if (!entry) {
  throw new Error(`No se encontró la sección "${slug}" en src/content/site/. Verifica que el archivo .md exista.`);
}
const { Content } = await render(entry);
---

<FadeIn class={className} duration={0.6} y={20}>
  {showTitle && entry.data.titulo && (
    <h2 class="font-display text-3xl font-semibold tracking-tight text-[var(--color-foreground)] sm:text-4xl">
      {entry.data.titulo}
    </h2>
  )}
  <div class={`prose-custom ${proseClass}`}>
    <Content />
  </div>
</FadeIn>

<style is:global>
  .prose-custom {
    color: var(--color-foreground);
    line-height: 1.7;
    font-size: 1.0625rem;
  }
  .prose-custom > * + * { margin-top: 1.1em; }
  .prose-custom h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.25em;
    margin-bottom: 0.6em;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .prose-custom h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 1.8em;
    margin-bottom: 0.5em;
    color: var(--color-foreground);
  }
  .prose-custom p { text-wrap: pretty; }
  .prose-custom strong { color: var(--color-foreground); font-weight: 600; }
  .prose-custom em { color: var(--color-accent); font-style: italic; }
  .prose-custom a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-decoration-thickness 0.2s;
  }
  .prose-custom a:hover { text-decoration-thickness: 2px; }
  .prose-custom ul { padding-left: 1.4em; list-style: disc; }
  .prose-custom ol { padding-left: 1.4em; list-style: decimal; }
  .prose-custom li { margin-top: 0.4em; }
  .prose-custom li::marker { color: var(--color-accent); }
  .prose-custom blockquote {
    border-left: 3px solid var(--color-accent);
    padding: 0.25em 0 0.25em 1em;
    color: var(--color-muted-foreground);
    font-style: italic;
    margin: 1.5em 0;
  }
  .prose-custom code {
    background: var(--color-muted);
    padding: 0.15em 0.4em;
    border-radius: 0.3em;
    font-size: 0.9em;
  }
  .prose-custom hr {
    border: none;
    border-top: 1px dashed var(--color-border);
    margin: 2em 0;
  }
</style>
