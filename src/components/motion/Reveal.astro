---
// ponytail: unifica los 3 motion (BlurFade/FadeIn/Stagger) — un solo observer compartido
export interface Props {
  delay?: number;
  duration?: number;
  y?: number;
  blur?: number;
  as?: "div" | "section" | "article" | "header" | "footer" | "aside" | "span" | "p" | "h1" | "h2" | "h3" | "h4";
  class?: string;
}

const { delay = 0, duration = 0.7, y = 16, blur = 0, as: Tag = "div", class: className = "" } = Astro.props;
const styleAttr = `--rv-delay:${delay}s;--rv-duration:${duration}s;--rv-y:${y}px;--rv-blur:${blur}px;`;
---

<Tag data-reveal style={styleAttr} class={`rv-init ${className}`}>
  <slot />
</Tag>

<style>
  .rv-init {
    opacity: 0;
    transform: translateY(var(--rv-y));
    filter: blur(var(--rv-blur));
    transition:
      opacity var(--rv-duration, 0.7s) cubic-bezier(0.22, 1, 0.36, 1) var(--rv-delay, 0s),
      transform var(--rv-duration, 0.7s) cubic-bezier(0.22, 1, 0.36, 1) var(--rv-delay, 0s),
      filter var(--rv-duration, 0.7s) cubic-bezier(0.22, 1, 0.36, 1) var(--rv-delay, 0s);
  }
  .rv-init.is-visible { opacity: 1; transform: translateY(0); filter: blur(0); }
  @media (prefers-reduced-motion: reduce) {
    .rv-init { opacity: 1; transform: none; filter: none; transition: none; }
  }
</style>

<script>
  const init = () => {
    const els = document.querySelectorAll<HTMLElement>("[data-reveal]");
    if (!els.length) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches || !("IntersectionObserver" in window)) {
      els.forEach((el) => el.classList.add("is-visible"));
      return;
    }
    const io = new IntersectionObserver(
      (es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("is-visible"); io.unobserve(e.target); } }),
      { rootMargin: "0px 0px -8% 0px", threshold: 0.05 }
    );
    els.forEach((el) => io.observe(el));
  };
  init();
  document.addEventListener("astro:page-load", init);
</script>
