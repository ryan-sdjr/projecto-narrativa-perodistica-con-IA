---
import Reveal from "../motion/Reveal.astro";
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/"); // ponytail: --base sin trailing slash
---

<section id="video-documental" class="relative overflow-hidden pt-28 pb-16 md:pt-36 md:pb-24" aria-labelledby="video-titulo">
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style={`background-image: url('${base}images/backgorund.png'); mask-image: linear-gradient(to bottom, transparent 0%, black 110px, black 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 110px, black 100%);`}
    aria-hidden="true"
  >
    <div class="absolute inset-0 bg-black/90 backdrop-blur-md"></div>
  </div>

  <div class="container-page relative z-20 mx-auto max-w-5xl">
    <div class="mx-auto mb-10 max-w-3xl text-center md:mb-14">
      <Reveal as="h2" id="video-titulo" delay={0.15} duration={0.8} class="font-display text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl text-balance">
        Video Reportaje
      </Reveal>
      <Reveal delay={0.2} class="mx-auto mt-4 max-w-2xl text-base text-zinc-300 text-pretty sm:text-lg">
        Grupo 5.
      </Reveal>
    </div>

    <Reveal delay={0.25} duration={0.9} class="mx-auto w-full max-w-4xl">
      <div class="relative aspect-video w-full overflow-hidden rounded-3xl border border-white/15 bg-black/80 shadow-2xl">
        <iframe width="560" height="315" src="https://www.youtube.com/embed/4GM66OHT37w?si=eCQodAT0mXbq2a52" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen; class="h-full w-full border-0"></iframe>
      </div>
    </Reveal>

    <footer class="mt-16 border-t border-white/15 pt-8 md:mt-24">
      <div class="flex flex-col items-center justify-between gap-4 text-center text-sm text-zinc-400 sm:flex-row sm:text-left">
        <p>© {new Date().getFullYear()} Universidad Autónoma del Perú. Artículo informativo.</p>
        <p class="text-xs">Construido con Astro · Hecho con propósito educativo</p>
      </div>
    </footer>
  </div>
</section>
