---
import MarkdownSection from "../content/MarkdownSection.astro";
import BlurFade from "../motion/BlurFade.astro";
---

<section
  id="conclusiones"
  class="relative py-16 md:py-24"
  aria-labelledby="conclusiones-titulo"
>
  <div class="container-page">
    <div class="mx-auto max-w-3xl">
      <BlurFade class="mb-8 flex items-center gap-3" duration={0.6}>
      </BlurFade>
      <MarkdownSection slug="conclusions" />
    </div>
  </div>
</section>
