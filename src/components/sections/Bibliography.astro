---
import MarkdownSection from "../content/MarkdownSection.astro";
---

<section id="bibliografia" class="relative py-16 md:py-24" aria-labelledby="biblio-titulo">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[var(--color-accent)]/40 to-transparent" aria-hidden="true"></div>
  <div class="container-page">
    <div class="mx-auto max-w-4xl">
      <MarkdownSection slug="bibliography" />
    </div>
  </div>
</section>
