---
import { getCollection, render } from "astro:content";
import Reveal from "../motion/Reveal.astro";
import strings from "../../data/strings.json";

const ejes = (await getCollection("site", ({ id }) => id.startsWith("ejes/"))).sort((a, b) => a.data.orden - b.data.orden);
const paneles = await Promise.all(ejes.map(async (e) => ({ entry: e, Content: (await render(e)).Content })));
---

<section id="ejes" class="relative pt-16 pb-8 md:pt-24 md:pb-12" aria-labelledby="ejes-titulo">
  <div class="container-page">
    <Reveal as="h2" id="ejes-titulo" duration={0.7} class="text-center font-display text-3xl font-semibold tracking-tight text-[var(--color-foreground)] sm:text-4xl md:text-5xl">
      3 ejes principales
    </Reveal>
    <Reveal delay={0.15} class="mx-auto mt-4 max-w-2xl text-center text-[var(--color-muted-foreground)]">
      Toca cada eje para descubrir la biología que hay detrás de la vulnerabilidad adolescente.
    </Reveal>

    <div class="mt-10 md:mt-14" data-tabs>
      <div role="tablist" aria-label={strings.tabs.ariaLabel} class="flex flex-wrap justify-center gap-2 sm:gap-3">
        {paneles.map(({ entry }, i) => (
          <button
            type="button"
            role="tab"
            id={`tab-${entry.id}`}
            aria-controls={`panel-${entry.id}`}
            aria-selected={i === 0 ? "true" : "false"}
            tabindex={i === 0 ? 0 : -1}
            data-tab-trigger={entry.id}
            class={`eje-tab relative inline-flex items-center gap-2 rounded-full border px-5 py-2.5 text-sm font-semibold sm:text-base ${
              i === 0
                ? "border-[var(--color-primary)] bg-[var(--color-primary)] text-[var(--color-primary-foreground)] shadow-md"
                : "border-[var(--color-border)] bg-[var(--color-card)] text-[var(--color-foreground)] hover:border-[var(--color-accent)] hover:bg-[var(--color-muted)]"
            }`}
          >
            <span class="grid h-6 w-6 place-items-center rounded-full text-xs font-bold">{i + 1}</span>
            <span>Eje {i + 1}</span>
          </button>
        ))}
      </div>

      <div class="mt-8 md:mt-12">
        {paneles.map(({ entry, Content }, i) => (
          <div
            role="tabpanel"
            id={`panel-${entry.id}`}
            aria-labelledby={`tab-${entry.id}`}
            data-tab-panel={entry.id}
            hidden={i !== 0}
            class="eje-panel"
          >
            <div class="mx-auto max-w-3xl rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 shadow-sm sm:p-8 md:p-10">
              <div class="mb-4 flex items-start gap-3">
                <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-[var(--color-accent-foreground)]">{i + 1}</span>
                <div>
                  <h3 class="font-display text-2xl font-semibold text-[var(--color-foreground)] sm:text-3xl">{entry.data.titulo}</h3>
                  {entry.data.subtitulo && <p class="mt-1 text-sm font-medium text-[var(--color-accent)] sm:text-base">{entry.data.subtitulo}</p>}
                </div>
              </div>
              <div class="prose-custom"><Content /></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
