---
---

<div id="shader-bg-root" class="fixed inset-0 pointer-events-none -z-20 overflow-hidden">
  <canvas id="shader-canvas" class="h-full w-full block transition-opacity duration-700 opacity-100"></canvas>
  <div id="shader-overlay" class="fixed inset-0 bg-black/80 pointer-events-none -z-10 transition-opacity duration-700 opacity-100" aria-hidden="true"></div>
</div>

<script>
  // ponytail: shader de fondo (WebGL). Apagado por defecto si el usuario prefiere menos movimiento
  const KEY = "shader-enabled";

  const initShader = () => {
    const root = document.getElementById("shader-bg-root");
    const canvas = document.getElementById("shader-canvas") as HTMLCanvasElement | null;
    const overlay = document.getElementById("shader-overlay");
    if (!root || !canvas) return;

    const gl = canvas.getContext("webgl") as WebGLRenderingContext | null;
    if (!gl) { canvas.style.display = overlay!.style.display = "none"; return; }

    const vs = `attribute vec2 a_position;void main(){gl_Position=vec4(a_position,0.,1.);}`;
    const fs = `
      precision highp float;
      uniform vec2 u_resolution;
      uniform float u_time;
      void main(){
        vec2 uv=(gl_FragCoord.xy*2.-u_resolution)/min(u_resolution.y,u_resolution.x);
        float d=-u_time*.07,a=0.;
        for(float i=0.;i<8.;++i){a+=cos(i-d-a*uv.x);d+=sin(uv.y*i+a);}
        d+=u_time*.07;
        float t=cos(a+d)*.5+.5,t2=sin(d*.8+uv.x*1.5)*.5+.5,t3=cos(a*.7-uv.y*1.5)*.5+.5;
        vec3 c=mix(vec3(.04,.02,.015),vec3(.35,.15,.05),t*.6);
        c=mix(c,vec3(.45,.20,.07),t2*.5);
        c=mix(c,vec3(.55,.28,.10),pow(t3*t,3.)*.4);
        gl_FragColor=vec4(c,1.);
      }`;

    const mk = (t: number, s: string) => {
      const sh = gl.createShader(t)!;
      gl.shaderSource(sh, s); gl.compileShader(sh);
      return gl.getShaderParameter(sh, gl.COMPILE_STATUS) ? sh : null;
    };
    const prog = gl.createProgram()!;
    gl.attachShader(prog, mk(gl.VERTEX_SHADER, vs)!);
    gl.attachShader(prog, mk(gl.FRAGMENT_SHADER, fs)!);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) return;
    gl.useProgram(prog);

    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1,1,-1,-1,1,1,1]), gl.STATIC_DRAW);
    const pos = gl.getAttribLocation(prog, "a_position");
    gl.enableVertexAttribArray(pos);
    gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);

    const res = gl.getUniformLocation(prog, "u_resolution");
    const tim = gl.getUniformLocation(prog, "u_time");
    const t0 = performance.now();
    let raf = 0, running = false;

    const resize = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      const w = Math.floor(innerWidth * dpr), h = Math.floor(innerHeight * dpr);
      if (canvas.width !== w) { canvas.width = w; canvas.height = h; gl.viewport(0, 0, w, h); }
    };

    const frame = (now: number) => {
      if (!running) return;
      resize();
      gl.uniform2f(res, canvas.width, canvas.height);
      gl.uniform1f(tim, (now - t0) * 0.001);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
      raf = requestAnimationFrame(frame);
    };

    const start = () => { if (running) return; running = true; canvas.style.opacity = overlay!.style.opacity = "1"; raf = requestAnimationFrame(frame); };
    const stop  = () => { running = false; canvas.style.opacity = overlay!.style.opacity = "0"; cancelAnimationFrame(raf); };

    const sync = () => {
      const stored = localStorage.getItem(KEY);
      const on = stored !== null ? stored === "true" : !matchMedia("(prefers-reduced-motion: reduce)").matches;
      on ? start() : stop();
      dispatchEvent(new CustomEvent("shader-state-changed", { detail: { enabled: on } }));
    };

    addEventListener("toggle-shader-event", () => {
      const current = localStorage.getItem(KEY);
      const next = current === null ? !matchMedia("(prefers-reduced-motion: reduce)").matches : current === "false";
      localStorage.setItem(KEY, String(next));
      sync();
    });
    addEventListener("resize", resize);
    sync();
  };
  initShader();
  document.addEventListener("astro:page-load", initShader);
</script>
