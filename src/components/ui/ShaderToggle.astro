---
---

<div class="fixed bottom-4 right-4 z-40">
  <button
    type="button"
    data-shader-toggle-btn
    aria-label="Desactivar o activar fondo 3D"
    title="Alternar fondo 3D"
    class="group inline-flex cursor-pointer items-center gap-2 rounded-full border border-[color-mix(in_oklab,var(--color-border)_80%,transparent)] bg-[color-mix(in_oklab,var(--color-card)_85%,transparent)] px-3.5 py-2 text-xs font-medium text-[var(--color-foreground)] shadow-lg backdrop-blur-md transition-transform hover:scale-105 active:scale-95"
  >
    <span data-shader-dot class="h-2 w-2 rounded-full bg-emerald-400 transition-colors"></span>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)] transition-transform group-hover:rotate-12" aria-hidden="true">
      <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
    </svg>
    <span data-shader-text>Fondo 3D: ON</span>
  </button>
</div>

<script>
  const init = () => {
    const btn = document.querySelector<HTMLButtonElement>("[data-shader-toggle-btn]");
    if (!btn) return;
    const dot = btn.querySelector<HTMLElement>("[data-shader-dot]")!;
    const text = btn.querySelector<HTMLElement>("[data-shader-text]")!;
    const KEY = "shader-enabled";

    const render = (on: boolean) => {
      dot.className = `h-2 w-2 rounded-full transition-colors ${on ? "bg-emerald-400 animate-pulse" : "bg-zinc-500"}`;
      text.textContent = `Fondo 3D: ${on ? "ON" : "OFF"}`;
      btn.setAttribute("aria-pressed", String(on));
    };

    btn.addEventListener("click", () => dispatchEvent(new CustomEvent("toggle-shader-event")));
    addEventListener("shader-state-changed", (e: Event) => render((e as CustomEvent).detail.enabled));

    const stored = localStorage.getItem(KEY);
    render(stored !== null ? stored === "true" : !matchMedia("(prefers-reduced-motion: reduce)").matches);
  };
  init();
  document.addEventListener("astro:page-load", init);
</script>
