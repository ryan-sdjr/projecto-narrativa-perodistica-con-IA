---
import "../styles/globals.css";
import strings from "../data/strings.json";

interface Props {
  titulo?: string;
  descripcion?: string;
  imagenOg?: string;
}

const {
  titulo = strings.site.nombre,
  descripcion = "Artículo informativo sobre por qué los adolescentes son biológicamente vulnerables a la manipulación digital.",
  imagenOg = "/og-image.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/"); // ponytail: --base sin trailing slash (Actions)
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#c75a1c" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#d97a3f" media="(prefers-color-scheme: dark)" />

    <link rel="icon" type="image/png" href={`${base}images/Autonoma_logov2.png`} />
    <link rel="canonical" href={canonical} />

    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
    <meta name="author" content={strings.site.autor} />

    <meta property="og:type" content="article" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(imagenOg, Astro.site).toString()} />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content={strings.site.nombre} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={new URL(imagenOg, Astro.site).toString()} />

    <link rel="preconnect" href="https://modelviewer.dev" crossorigin />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      headline: titulo,
      description: descripcion,
      inLanguage: "es",
      author: { "@type": "Organization", name: strings.site.autor },
      publisher: { "@type": "Organization", name: strings.site.autor },
    })} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[var(--color-accent)] focus:text-[var(--color-accent-foreground)] focus:rounded-md">
      {strings.ui.saltarASeccion}
    </a>
    <slot />
  </body>
</html>

<script>
  // ponytail: tabs ARIA unificados — un solo handler para EjesTabs y BrainViewer
  const initTabs = () => {
    document.querySelectorAll<HTMLElement>("[data-tabs]").forEach((root) => {
      const triggers = root.querySelectorAll<HTMLButtonElement>("[data-tab-trigger]");
      const panels = root.querySelectorAll<HTMLElement>("[data-tab-panel]");
      if (!triggers.length) return;

      const activate = (id: string) => {
        let orbit: string | undefined;
        triggers.forEach((t) => {
          const on = t.dataset.tabTrigger === id;
          t.setAttribute("aria-selected", String(on));
          t.tabIndex = on ? 0 : -1;
          t.classList.toggle("is-active", on);
          if (on) orbit = t.dataset.orbit;
        });
        panels.forEach((p) => p.toggleAttribute("hidden", p.dataset.tabPanel !== id));
        // ponytail: si un trigger lleva data-orbit, sincroniza el model-viewer del root
        if (orbit) root.querySelector("model-viewer")?.setAttribute("camera-orbit", orbit);
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener("click", () => activate(trigger.dataset.tabTrigger!));
        trigger.addEventListener("keydown", (e) => {
          const list = [...triggers];
          const i = list.indexOf(trigger);
          const next =
            e.key === "ArrowRight" ? (i + 1) % list.length :
            e.key === "ArrowLeft" ? (i - 1 + list.length) % list.length :
            e.key === "Home" ? 0 :
            e.key === "End" ? list.length - 1 : -1;
          if (next < 0) return;
          e.preventDefault();
          list[next].focus();
          activate(list[next].dataset.tabTrigger!);
        });
      });
    });
  };

  // ponytail: model-viewer (~300KB) solo se carga cuando BrainViewer entra en viewport
  const initModelViewer = () => {
    const targets = document.querySelectorAll("model-viewer");
    if (!targets.length) return;
    const load = () => {
      if (document.querySelector("script[data-mv]")) return;
      const s = document.createElement("script");
      s.type = "module";
      s.src = "https://ajax.googleapis.com/ajax/libs/model-viewer/4.0.0/model-viewer.min.js";
      s.dataset.mv = "1";
      document.head.appendChild(s);
    };
    if (!("IntersectionObserver" in window)) { load(); return; }
    const io = new IntersectionObserver((es) => {
      if (es.some((e) => e.isIntersecting)) { load(); io.disconnect(); }
    }, { rootMargin: "200px" });
    targets.forEach((el) => io.observe(el));
  };

  const init = () => { initTabs(); initModelViewer(); };
  init();
  document.addEventListener("astro:page-load", init);
</script>
